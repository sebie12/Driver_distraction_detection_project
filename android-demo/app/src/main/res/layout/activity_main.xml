<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/txtSelectedModel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Modelo ativo:"
        android:textSize="16sp"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/txtLastInference"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Última inferência: sem dados"
        android:textSize="14sp"
        android:paddingBottom="8dp" />

    <Button
        android:id="@+id/btnSelectModel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Selecionar modelo" />

    <Button
        android:id="@+id/btnInspectModel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Inspecionar modelo" />

    <CheckBox
        android:id="@+id/cbDebugWindowSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Modo debug: exportar resumo por janela" />

    <Button
        android:id="@+id/btnToggle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Iniciar" />

    <Button
        android:id="@+id/btnExport"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Exportar sessão" />



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="18dp">

        <Button
            android:id="@+id/btnDistract"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Distração" />
    </LinearLayout>

</LinearLayout>